# ─────────────────────────────────────────────
# Fern-OS — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# JWT secret for token authentication (required)
JWT_SECRET=your-super-secret-jwt-key

# Worker authentication token (optional — leave empty to skip worker auth checks)
WORKER_AUTH_TOKEN=

# PostgreSQL password (defaults to fernos_pass if unset)
DB_PASSWORD=fernos_pass

# MinIO Configuration
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=fernos-storage
